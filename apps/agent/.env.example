# Paladin Agent — optional local bootstrap
# 复制此文件为 .env 仅用于本地开发播种 provider；桌面端 AI Provider 面板是主要配置路径。
# Paladin 可以在没有这些变量的情况下启动。

# Generic AI provider bootstrap
# PALADIN_AI_PROVIDER 支持：deepseek, openai-compatible, lm-studio
PALADIN_AI_PROVIDER=deepseek
PALADIN_AI_BASE_URL=https://api.deepseek.com/v1
PALADIN_AI_MODEL=deepseek-chat
PALADIN_AI_API_KEY=<your-api-key>

# Legacy DeepSeek compatibility.
# 如果只设置 DEEPSEEK_API_KEY，Paladin 会把它作为 DeepSeek provider 的首次启动种子。
# DEEPSEEK_API_KEY=<your-api-key>

# LM Studio example: 通常不需要真实 API key，但保留占位值以兼容 OpenAI-style 客户端。
# PALADIN_AI_PROVIDER=lm-studio
# PALADIN_AI_BASE_URL=http://localhost:1234/v1
# PALADIN_AI_MODEL=local-model
# PALADIN_AI_API_KEY=<local-placeholder>
