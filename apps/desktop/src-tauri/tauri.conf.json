{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "paladin",
  "version": "0.1.0",
  "identifier": "com.worsmer.paladin",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Paladin",
        "width": 1200,
        "height": 800,
        "center": true,
        "resizable": true,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://localhost:* https://*.copilotkit.ai; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/paladin-agent-sidecar",
      "binaries/paladin-server-sidecar"
    ],
    "resources": ["processes.packaged.json"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
