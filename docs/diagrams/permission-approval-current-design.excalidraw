    {
      "type": "text",
      "id": "evidence_agui_text",
      "x": 592,
      "y": 392,
      "width": 520,
      "height": 150,
      "text": "if mode == \"agui_interrupt\":\n  interrupt_on = {\n    tool_name: True\n    for tool_name in require_approval\n  }\n  approval_callback = None\n  Tool(computer_tool, requires_approval=True)\ncreate_deep_agent(..., interrupt_on=interrupt_on)",
      "originalText": "if mode == \"agui_interrupt\":\n  interrupt_on = {\n    tool_name: True\n    for tool_name in require_approval\n  }\n  approval_callback = None\n  Tool(computer_tool, requires_approval=True)\ncreate_deep_agent(..., interrupt_on=interrupt_on)",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
