    {
      "type": "text",
      "id": "evidence_config_text",
      "x": 92,
      "y": 392,
      "width": 430,
      "height": 150,
      "text": "\"hitl\": {\n  \"require_approval\": [\n    \"execute\", \"write_file\",\n    \"edit_file\"\n  ],\n  \"blocked\": [],\n  \"timeout_seconds\": 30\n}\nmode 缺省值: \"agui_interrupt\"",
      "originalText": "\"hitl\": {\n  \"require_approval\": [\n    \"execute\", \"write_file\",\n    \"edit_file\"\n  ],\n  \"blocked\": [],\n  \"timeout_seconds\": 30\n}\nmode 缺省值: \"agui_interrupt\"",
