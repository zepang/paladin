{
  "name": "paladin",
  "private": true,
  "description": "AI 编程助手桌面端",
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "check": "biome ci .",
    "test": "pnpm --filter @paladin/desktop test --run && node --test apps/desktop/scripts/*.test.mjs",
    "release": "pnpm --filter @paladin/desktop release"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4"
  },
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  }
}
